FIREBASE_SERVICE_ACCOUNT_KEY=env/firebase-key.json
FIREBASE_STORAGE_BUCKET=globaltalentbridge-e492e.firebasestorage.app

# Dashboard Config
# Defina como 'true' para usar dados reais do Firebase (requer conexão estável)
# Defina como 'false' para usar dados simulados (Mock Data) de alta qualidade
USE_FIREBASE_DASHBOARD=false
